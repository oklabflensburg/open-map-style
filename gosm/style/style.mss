Map {
  background-color: @land-color;
}

@base-100: #ffffff;
@base-99: #fdfdfd;
@base-98: #fbfbfb;
@base-97: #fbfbfb;
@base-96: #fafafa;
@base-95: #f8f8f8;
@base-94: #f6f6f6;
@base-92: #f3f3f3;
@base-90: #efefef;
@base-88: #ebebeb;
@base-84: #e2e2e2;
@base-80: #d9d9d9;
@base-76: #cfcfcf;
@base-72: #c5c5c5;
@base-68: #bbbbbb;
@base-64: #b1b1b1;
@base-60: #a7a7a7;
@base-56: #9d9d9d;
@base-52: #939393;
@base-48: #898989;
@base-44: #7d7d7d;
@base-40: #727272;
@base-36: #686868;
@base-32: #5e5e5e;

@land-color: #fbfbfb;
@background: @land-color;
@water-color: #f1f1f1;
@water: @water-color;
@water-deep: #e6e6e6;
@water-line: #d0d0d0;
@water-text-soft: #a0a0a0;

@road_major: @base-100;
@road_minor: @base-99;
@road_path: @base-76;
@road_track: @base-72;
@road_casing: @base-72;
@road_casing_strong: @base-56;
@road_casing_dark: @base-44;
@road_marking: @base-94;
@road_marking_light: @base-98;

@building_fill: #e8e8e8;
@building_line: #cdcdcd;

@park: #f7f7f7;
@forest: #f3f3f3;
@grass: #f8f8f8;
@farmland: #f6f6f6;
@industrial: #f3f3f3;
@residential: #f5f5f5;
@cemetery: #f3f3f3;
@sand-neutral: #f7f7f7;
@bare-ground: #f3f3f3;

@railway: @base-60;
@boundary: #d7d7d7;
@boundary-strong: #c2c2c2;

@label: #727272;
@label-light: #949494;
@label-strong: #606060;
@halo: rgba(255,255,255,0.88);

@standard-halo-radius: 1.2;
@standard-halo-fill: @halo;
