Map {
  background-color: @land-color;
}

@base-100: #ffffff;
@base-99: #fdfdfd;
@base-98: #fbfbfb;
@base-97: #fafafa;
@base-96: #f8f8f8;
@base-95: #f6f6f6;
@base-94: #f4f4f4;
@base-92: #f0f0f0;
@base-90: #ebebeb;
@base-88: #e5e5e5;
@base-84: #dbdbdb;
@base-80: #d1d1d1;
@base-76: #c6c6c6;
@base-72: #bbbbbb;
@base-68: #b0b0b0;
@base-64: #a5a5a5;
@base-60: #9a9a9a;
@base-56: #8f8f8f;
@base-52: #848484;
@base-48: #797979;
@base-44: #6d6d6d;
@base-40: #636363;
@base-36: #595959;
@base-32: #4f4f4f;

@land-color: #f8f8f8;
@background: @land-color;
@water-color: #ebebeb;
@water: @water-color;
@water-deep: #dddddd;
@water-line: #c4c4c4;
@water-text-soft: #959595;

@road_major: @base-100;
@road_minor: @base-99;
@road_path: @base-76;
@road_track: @base-72;
@road_casing: @base-72;
@road_casing_strong: @base-56;
@road_casing_dark: @base-44;
@road_marking: @base-94;
@road_marking_light: @base-98;

@building_fill: #e1e1e1;
@building_line: #c3c3c3;

@park: #f3f3f3;
@forest: #ededed;
@grass: #f4f4f4;
@farmland: #f2f2f2;
@industrial: #ededed;
@residential: #f1f1f1;
@cemetery: #efefef;
@sand-neutral: #f3f3f3;
@bare-ground: #efefef;

@railway: @base-60;
@boundary: #cbcbcb;
@boundary-strong: #b6b6b6;

@label: #666666;
@label-light: #888888;
@label-strong: #555555;
@halo: rgba(255,255,255,0.88);

@standard-halo-radius: 1.2;
@standard-halo-fill: @halo;
