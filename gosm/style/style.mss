Map {
  background-color: @land-color;
}

@base-100: #ffffff;
@base-99: #fdfdfc;
@base-98: #fbfbfa;
@base-97: #f8f8f7;
@base-96: #f6f6f4;
@base-95: #f3f3f1;
@base-94: #f1f1ef;
@base-92: #ecebe8;
@base-90: #e6e5e2;
@base-88: #dfdedb;
@base-84: #d2d1cd;
@base-80: #c7c5c0;
@base-76: #bbb9b5;
@base-72: #afada8;
@base-68: #a3a19c;
@base-64: #97958f;
@base-60: #8c8984;
@base-56: #807d79;
@base-52: #74716d;
@base-48: #696662;
@base-44: #5e5b57;
@base-40: #534f4c;
@base-36: #484542;
@base-32: #3f3c39;

@land-color: #f5f4f1;
@background: @land-color;
@water-color: #dde3e6;
@water: @water-color;
@water-deep: #c8d1d6;
@water-line: #b3bdc4;
@water-text-soft: #7c868d;

@road_major: @base-100;
@road_minor: @base-99;
@road_path: @base-76;
@road_track: @base-72;
@road_casing: @base-72;
@road_casing_strong: @base-56;
@road_casing_dark: @base-44;
@road_marking: @base-94;
@road_marking_light: @base-98;

@building_fill: #d8d5d0;
@building_line: #b6b2ac;

@park: #ecefe9;
@forest: #e4e8e1;
@grass: #eef1ec;
@farmland: #efefe8;
@industrial: #e7e5e2;
@residential: #eceae7;
@cemetery: #e7ebe6;
@sand-neutral: #f0ede6;
@bare-ground: #ece8e1;

@railway: @base-60;
@boundary: #c1bdb8;
@boundary-strong: #aaa59f;

@label: #56534f;
@label-light: #7a7672;
@label-strong: #403d3a;
@halo: rgba(255,255,255,0.88);

@standard-halo-radius: 1.2;
@standard-halo-fill: @halo;
